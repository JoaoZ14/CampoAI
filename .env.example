# Servidor
PORT=3001

# Supabase (Project Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# Sem cota na API? Teste o fluxo inteiro sem IA real:
# MOCK_LLM=true

# IA — use uma opção (Gemini tem plano gratuito no Google AI Studio)
# Obter chave: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Opcional se o padrão der 404 na sua região/conta:
# GEMINI_MODEL=gemini-2.0-flash-001

# Reintentos automáticos em 503/alta demanda/429 (padrão: 3 tentativas, 2s base)
# GEMINI_RETRY_ATTEMPTS=5
# GEMINI_RETRY_MS=2500

# Tamanho máximo da resposta em tokens (padrão 4096; máx. 8192 — evita cortar no meio)
# LLM_MAX_OUTPUT_TOKENS=4096

# Webhook Z-API: só use se souber o risco (resposta pode não ir ao WhatsApp se o processo cair)
# ZAPI_WEBHOOK_ASYNC_ACK=true

# Z-API (painel → Instâncias → ID e Token da instância)
# Base URL da API: https://api.z-api.io/instances/{id}/token/{token}/...
ZAPI_INSTANCE_ID=
ZAPI_INSTANCE_TOKEN=
# Token de segurança da conta (header Client-Token) — obrigatório se ativou em Segurança no painel
ZAPI_CLIENT_TOKEN=

# Opcional: desativa envio real (útil para testes só com Postman)
# MOCK_WHATSAPP=true

# Opcional: URLs de mídia do Twilio no Postman (Basic Auth)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
