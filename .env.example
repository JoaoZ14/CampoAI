# Servidor
PORT=3001

# Supabase (Project Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# Sem cota na API? Teste o fluxo inteiro sem IA real:
# MOCK_LLM=true

# IA — use uma opção (Gemini tem plano gratuito no Google AI Studio)
# Obter chave: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Opcional se o padrão der 404 na sua região/conta:
# GEMINI_MODEL=gemini-2.0-flash-001

# Reintentos automáticos em 503/alta demanda/429 (padrão: 3 tentativas, 2s base)
# GEMINI_RETRY_ATTEMPTS=5
# GEMINI_RETRY_MS=2500

# Tamanho máximo da resposta em tokens (padrão 4096; máx. 8192 — evita cortar no meio)
# LLM_MAX_OUTPUT_TOKENS=4096

# Webhook Twilio: só use se souber o risco (resposta pode não ir ao WhatsApp se o processo cair)
# TWILIO_WEBHOOK_ASYNC_ACK=true


# Twilio (WhatsApp sandbox ou número aprovado)
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
# Formato: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Opcional: desativa envio real no Twilio (útil para testes só com Postman)
# MOCK_WHATSAPP=true
