# Servidor
PORT=3001

# Supabase (Project Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key
# Chave anon (pública) — necessária para login do painel /admin no navegador
SUPABASE_ANON_KEY=sua_anon_key

# Painel dev em /admin — e-mails do Supabase Auth com acesso (separados por vírgula)
ADMIN_EMAILS=seu@email.com

# Opcional: URL pública do app (redirect do Supabase Auth); se vazio, usa Host do request
# PUBLIC_APP_URL=https://agassist.netlify.app/

# Link quando o uso gratuito acaba
# PAYWALL_URL=https://seu-dominio.com/planos
#
# Botões embaixo da mensagem (WhatsApp): criar template em Twilio → Messaging → Content Template Builder
# (tipo com botão URL), copiar o Content SID (H…) e colar aqui — sem isso só há link azul no texto.
# No template use {{1}} = texto e {{2}} = URL (ou defina PAYWALL_CONTENT_VARIABLES_JSON com o JSON exato).
# PAYWALL_CONTENT_SID=Hxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PAYWALL_CONTENT_VARIABLES_JSON={"1":"texto da mensagem","2":"https://..."}
#
# Sem PAYWALL_CONTENT_SID: duas bolhas de texto ou uma (link tocável — ver README)
# PAYWALL_CTA_LINE=Toque no link para ver os planos:
# PAYWALL_FIRST_MESSAGE=Texto completo da 1ª mensagem (substitui o texto padrão antes do link na 2ª bolha)
# PAYWALL_SINGLE_BUBBLE=true

# Memória da conversa no Gemini (tabela chat_messages no Supabase). Desligar: CHAT_HISTORY_ENABLED=false
# CHAT_HISTORY_MAX_MESSAGES=24

# Relatórios em PDF (Supabase Storage — crie o bucket, ex. "reports", privado)
# REPORTS_ENABLED=false
# SUPABASE_REPORTS_BUCKET=reports
# REPORT_HISTORY_MAX_MESSAGES=80
# REPORT_PDF_SIGNED_URL_SECONDS=3600
# WHATSAPP_REPORT_ERROR_TEXT=Não consegui gerar o PDF. Tente de novo em instantes.

# Sem cota na API? Teste o fluxo inteiro sem IA real:
# MOCK_LLM=true

# IA — use uma opção (Gemini tem plano gratuito no Google AI Studio)
# Obter chave: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Modelo principal (padrão no código: gemini-2.5-flash). gemini-2.0-flash não está mais disponível para contas novas (404).
# GEMINI_MODEL=gemini-2.5-flash
# Ex.: Gemini 3 Flash — use o ID exato da documentação / AI Studio (preview costuma ser gemini-3-flash-preview; se der 404, copie o nome do modelo na lista).
# GEMINI_MODEL=gemini-3-flash-preview
# Opcional: modelo extra na cadeia (entre o principal e o fallback automático)
# GEMINI_MODEL_FALLBACK=
# Se o principal falhar (ex. 503), tenta este ID automaticamente (padrão: gemini-2.5-flash-lite)
# GEMINI_AUTO_FALLBACK_MODEL=gemini-2.5-flash-lite
# Desliga o fallback automático
# GEMINI_DISABLE_AUTO_FALLBACK=true

# Retentativas no MESMO modelo (padrão: 1 = sem fila; resposta o mais rápido possível).
# Só aumente se quiser insistir após 503: GEMINI_RETRY_ATTEMPTS=3
# GEMINI_RETRY_ATTEMPTS=1
# Pausa entre retentativas no mesmo modelo (ms; só vale se ATTEMPTS > 1)
# GEMINI_RETRY_MS=800

# Tamanho máximo da resposta em tokens (padrão 4096; máx. 8192 — evita cortar no meio)
# LLM_MAX_OUTPUT_TOKENS=4096

# Webhook Twilio: padrão = responde 200 rápido e processa em background (evita timeout ~15s do Twilio).
# Só use se precisar que o 200 só saia depois de tudo processado (ex.: debug):
# TWILIO_WEBHOOK_SYNC=true

# Opcional: mensagem imediata antes da IA (feedback enquanto gera)
# WHATSAPP_IA_ACK_TEXT=Um instante — estou analisando e já te respondo.

# Opcional: texto se a IA falhar (senão usa mensagem padrão do código)
# WHATSAPP_IA_ERROR_TEXT=Não consegui responder agora. Tente de novo em instantes.

# Asaas — assinatura mensal com cartão (API v3)
# Chave em Integrações → API (sandbox: https://sandbox.asaas.com/)
# ASAAS_API_KEY=whsec_tfFtleEsPLoovSltUE8xOumXUyjf9W_c2uqb34R4FwY
# ASAAS_SANDBOX=true
# Webhook: URL pública POST …/webhook/asaas — token igual ao configurado no painel Asaas (header asaas-access-token)
# ASAAS_WEBHOOK_TOKEN=whsec_hrT6FCXe4NTxM7ED4IE4rvHDPacX88Ve3-ZuoKUHGHI
# Segredo para a página de planos chamar POST /api/billing/asaas/subscribe (header x-ag-checkout-secret). Em produção é obrigatório.
# ASAAS_CHECKOUT_API_SECRET=8b6a77e5be74d98a9b66f52e2c5e01c97f4b0202437cda95757edf21e24632c3
# Data da 1ª cobrança (AAAA-MM-DD); se vazio, usa hoje no fuso America/Sao_Paulo
# ASAAS_FIRST_CHARGE_DATE=2026-04-20

# OTP por WhatsApp para checkout da página /planos
# OTP_PHONE_TTL_MIN=5
# OTP_PHONE_TOKEN_TTL_MIN=30

# Twilio (WhatsApp sandbox ou número aprovado)
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
# Formato: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+12183878223

# Opcional: desativa envio real no Twilio (útil para testes só com Postman)
# MOCK_WHATSAPP=true

# Resumo semanal por WhatsApp (cron no servidor; horário via WEEKLY_NEWS_CRON)
# Teste manual (sem esperar segunda): npm run weekly-news  (ou weekly-news:send)
# Só um número na hora (não muda o .env), na raiz do projeto:
#   bash (Render/Linux): npm run weekly-news -- "+5511999999999"
#   PowerShell (Windows): npm run weekly-news -- "+5511999999999"
#   ou: npm run weekly-news -- --phone "+5511999999999"
# Variável só na sessão — bash: WEEKLY_NEWS_TO_PHONE="+55…" npm run weekly-news
#   PowerShell: $env:WEEKLY_NEWS_TO_PHONE="+55…"; npm run weekly-news
# Destinos: sem WEEKLY_NEWS_TO_PHONE, o cron e `npm run weekly-news` enviam para
# todos os telefones distintos em public.users. Com WEEKLY_NEWS_TO_PHONE, só esse número.
# Intervalo entre envios (ms) ao Twilio em modo broadcast (padrão 350)
# WEEKLY_NEWS_SEND_DELAY_MS=350
# Mensagens iniciadas pelo negócio podem exigir template aprovado no Meta/Twilio fora da janela de 24h.
# Com template aprovado (Content SID no Twilio): envio usa business initiated; omita a linha para texto+mídia na sessão.
# WEEKLY_NEWS_WHATSAPP_CONTENT_SID=HXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Variável do corpo no template ({{1}} → 1). Só mude se o template usar outro número.
# WEEKLY_NEWS_TEMPLATE_BODY_VAR_KEY=1
# Se o template tiver {{2}} (ou outro) para URL da imagem, defina o número da variável e use WEEKLY_NEWS_BANNER_IMAGE_URL.
# WEEKLY_NEWS_TEMPLATE_BANNER_VAR_KEY=2
# WEEKLY_NEWS_ENABLED=true
# WEEKLY_NEWS_TO_PHONE=+5511999999999
# Texto fixo e/ou fallback se GNews falhar ou vier vazio (pode ficar vazio se só usar GNews)
# WEEKLY_NEWS_BODY=Resumo semanal AG Assist\n\n• …\n• …
# GNews — chave em https://gnews.io/ (monta lista título + link, country=br, lang=pt)
# GNEWS_API_KEY=
# WEEKLY_NEWS_GNEWS_QUERY=agronegocio OR agricultura OR pecuaria OR safra OR equideos OR cavalos
# Máximo de matérias na API (padrão no código: 3). Aumente só se couber no template / tamanho da mensagem
# WEEKLY_NEWS_GNEWS_MAX=3
# Link “Ver mais notícias” no rodapé do resumo (padrão: página Notícias do site)
# WEEKLY_NEWS_MORE_URL=https://agassist.netlify.app/#noticias
# Tamanho máximo do título no WhatsApp (40–160; padrão 72 + reticências)
# WEEKLY_NEWS_TITLE_MAX_CHARS=72
# Mostrar nome da fonte após o título (GNews). Desligar: WEEKLY_NEWS_SHOW_SOURCE=false
# Marcador de cada notícia (padrão •). Ex.: → ou ▸ ou 🌾 (máx. ~12 caracteres)
# WEEKLY_NEWS_ITEM_MARKER=•
# Últimos N dias na busca (padrão 7)
# WEEKLY_NEWS_GNEWS_DAYS=7
# WEEKLY_NEWS_GNEWS_COUNTRY=br
# WEEKLY_NEWS_GNEWS_LANG=pt
# Onde buscar a query: title,description ou title (ver doc GNews `in`)
# WEEKLY_NEWS_GNEWS_IN=title,description
# WEEKLY_NEWS_HEADER=Resumo semanal — AG Assist (Brasil)
# WEEKLY_NEWS_FOOTER=Fontes: links acima (GNews).
# Banner opcional: URL HTTPS pública (Twilio baixa a imagem; PNG/JPG; tamanho razoável para WhatsApp)
# WEEKLY_NEWS_BANNER_IMAGE_URL=https://exemplo.com/storage/banner-semanal.png
# Opcional — fuso do horário do cron (padrão America/Sao_Paulo)
# WEEKLY_NEWS_TIMEZONE=America/Sao_Paulo
# Quando disparar: expressão cron node-cron (min hora dia_mês mês dia_semana).
# Padrão no código se omitir: 0 12 * * 1 (= segunda 12:00 no fuso acima).
# WEEKLY_NEWS_CRON=0 12 * * 1
