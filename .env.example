# Servidor
PORT=3001

# Supabase (Project Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key
# Chave anon (pública) — necessária para login do painel /admin no navegador
SUPABASE_ANON_KEY=sua_anon_key

# Painel dev em /admin — e-mails do Supabase Auth com acesso (separados por vírgula)
ADMIN_EMAILS=seu@email.com

# Opcional: URL pública do app (redirect do Supabase Auth); se vazio, usa Host do request
# PUBLIC_APP_URL=https://seu-dominio.com

# Sem cota na API? Teste o fluxo inteiro sem IA real:
# MOCK_LLM=true

# IA — use uma opção (Gemini tem plano gratuito no Google AI Studio)
# Obter chave: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Modelo principal (padrão no código: gemini-2.5-flash). gemini-2.0-flash não está mais disponível para contas novas (404).
# GEMINI_MODEL=gemini-2.5-flash
# Ex.: Gemini 3 Flash — use o ID exato da documentação / AI Studio (preview costuma ser gemini-3-flash-preview; se der 404, copie o nome do modelo na lista).
# GEMINI_MODEL=gemini-3-flash-preview
# Opcional: modelo extra na cadeia (entre o principal e o fallback automático)
# GEMINI_MODEL_FALLBACK=
# Se o principal falhar (ex. 503), tenta este ID automaticamente (padrão: gemini-2.5-flash-lite)
# GEMINI_AUTO_FALLBACK_MODEL=gemini-2.5-flash-lite
# Desliga o fallback automático
# GEMINI_DISABLE_AUTO_FALLBACK=true

# Retentativas no MESMO modelo (padrão: 1 = sem fila; resposta o mais rápido possível).
# Só aumente se quiser insistir após 503: GEMINI_RETRY_ATTEMPTS=3
# GEMINI_RETRY_ATTEMPTS=1
# Pausa entre retentativas no mesmo modelo (ms; só vale se ATTEMPTS > 1)
# GEMINI_RETRY_MS=800

# Tamanho máximo da resposta em tokens (padrão 4096; máx. 8192 — evita cortar no meio)
# LLM_MAX_OUTPUT_TOKENS=4096

# Webhook Twilio: padrão = responde 200 rápido e processa em background (evita timeout ~15s do Twilio).
# Só use se precisar que o 200 só saia depois de tudo processado (ex.: debug):
# TWILIO_WEBHOOK_SYNC=true

# Opcional: mensagem imediata antes da IA (feedback enquanto gera)
# WHATSAPP_IA_ACK_TEXT=Um instante — estou analisando e já te respondo.

# Opcional: texto se a IA falhar (senão usa mensagem padrão do código)
# WHATSAPP_IA_ERROR_TEXT=Não consegui responder agora. Tente de novo em instantes.


# Twilio (WhatsApp sandbox ou número aprovado)
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
# Formato: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Opcional: desativa envio real no Twilio (útil para testes só com Postman)
# MOCK_WHATSAPP=true
